{
  "name": "Dev Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode-remote.vscode-remote-extensionpack",
        "ms-dotnettools.csharp",
        "ms-vscode.cpptools",
        "visualstudioexptteam.vscodeintellicode",
        "andrejunges.handlebars",
        "dakara.transformer",
        "dracula-theme.theme-dracula",
        "PKief.material-icon-theme",
        "oderwat.indent-rainbow",
        "aaron-bond.better-comments",
        "ms-python.python",
        "ms-python.isort",
        "golang.go",
        "redhat.java",
        "redhat.vscode-yaml",
        "wholroyd.jinja",
        "clinyong.vscode-css-modules",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "streetsidesoftware.code-spell-checker",
        "wmaurer.change-case",
        "nicoespeon.abracadabra",
        "formulahendry.code-runner",
        "ms-azuretools.vscode-docker",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "postStartCommand": "grep -qF '.bash_syle' \"$HOME/.bashrc\" 2>/dev/null || echo '[ -f \"$HOME/.bash_syle\" ] && source \"$HOME/.bash_syle\"\n[ -f \"$HOME/.bash_syle_advanced\" ] && source \"$HOME/.bash_syle_advanced\"\n[ -f \"$HOME/.codespace_profile\" ] && source \"$HOME/.codespace_profile\"' >> \"$HOME/.bashrc\""
}
